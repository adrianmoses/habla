{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "analiza/output_schema_v1.json",
  "title": "analiza examiner output v1",
  "type": "object",
  "required": ["puntuaciones", "errores", "subjuntivo", "mejoras", "enfoque_proxima_sesion"],
  "additionalProperties": false,
  "properties": {
    "puntuaciones": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["criterio", "puntuacion", "justificacion"],
        "additionalProperties": false,
        "properties": {
          "criterio": { "enum": ["coherencia", "fluidez", "correccion", "alcance"] },
          "puntuacion": { "type": "integer", "minimum": 1, "maximum": 3 },
          "justificacion": { "type": "string" }
        }
      }
    },
    "errores": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["dije", "deberia_ser", "por_que"],
        "additionalProperties": false,
        "properties": {
          "dije": { "type": "string" },
          "deberia_ser": { "type": "string" },
          "por_que": { "type": "string" }
        }
      }
    },
    "subjuntivo": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conector", "frase", "correcto"],
        "additionalProperties": false,
        "properties": {
          "conector": { "type": "string" },
          "frase": { "type": "string" },
          "correcto": { "type": "boolean" },
          "comentario": { "type": ["string", "null"] }
        }
      }
    },
    "mejoras": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["rodeo", "chunk_b2", "contexto"],
        "additionalProperties": false,
        "properties": {
          "rodeo": { "type": "string" },
          "chunk_b2": { "type": "string" },
          "contexto": { "type": "string" }
        }
      }
    },
    "enfoque_proxima_sesion": { "type": "string" }
  }
}
