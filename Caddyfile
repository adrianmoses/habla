# Caddy reverse proxy + static SPA host for the prod overlay
# (docker-compose.prod.yml). Automatic ACME TLS for $DOMAIN; terminates wss://
# and https:// at the edge. Requires public DNS for $DOMAIN pointing at this
# host with ports 80 + 443 reachable.
#
# The built SPA (spec #018) is baked into this Caddy image at /srv (see
# web/Dockerfile). Routing uses mutually-exclusive `handle` blocks so the static
# file_server can never shadow the WebSocket upgrade or the health probe:
#   - /ws/session*  → reverse_proxy app:8000 (Caddy forwards Upgrade/Connection
#                     and Sec-WebSocket-Protocol transparently, so the #016
#                     subprotocol auth token reaches the app unchanged).
#   - /health       → reverse_proxy app:8000 (readiness probe, spec #016).
#   - /api/*         → reverse_proxy app:8000 (learner-progress read API, spec
#                     #019; the SPA reads it same-origin with a Bearer token).
#   - everything else → serve the SPA, with a history-API fallback to
#                     index.html so client-side routes (/, /session) don't 404.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	handle /ws/session* {
		reverse_proxy app:8000
	}
	handle /health {
		reverse_proxy app:8000
	}
	handle /api/* {
		reverse_proxy app:8000
	}
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
