# App
HABLE_YA_HOST=0.0.0.0
HABLE_YA_PORT=8000
HABLE_YA_LOG_LEVEL=info

# Postgres DSN. docker-compose.yml overrides to `db:5432` for in-compose runs;
# on-host runs (uv run uvicorn …) use this value (host port 5433 → container 5432).
HABLE_YA_DATABASE_URL=postgresql://hable_ya:hable_ya@localhost:5433/hable_ya
# HABLE_YA_DB_POOL_MIN_SIZE=1
# HABLE_YA_DB_POOL_MAX_SIZE=4
# HABLE_YA_DB_POOL_TIMEOUT_SECONDS=5.0

# Deployment hardening (spec #017). The serving path fails fast at startup if the
# DB password is empty or the placeholder `hable_ya`. For LOCAL dev with the
# placeholder creds, opt out (docker-compose.yml already sets this for you):
# HABLE_YA_ALLOW_DEFAULT_DB_CREDENTIALS=true

# --- Production deployment (docker-compose.prod.yml) ---
# DB credentials injected into BOTH the app DSN and the Postgres container. No
# defaults in prod — compose refuses to start if unset. Generate a strong one:
#   openssl rand -base64 24
# POSTGRES_USER=habla
# POSTGRES_PASSWORD=
# POSTGRES_DB=habla
# Public hostname + ACME email for Caddy's automatic TLS (needs public DNS →
# this host, ports 80 + 443 reachable).
# DOMAIN=habla.example.com
# ACME_EMAIL=you@example.com

# LLM — Claude via the Anthropic API. Key read from the standard ANTHROPIC_API_KEY
# (no HABLE_YA_ prefix), matching the Anthropic SDK.
ANTHROPIC_API_KEY=
# HABLE_YA_LLM_MODEL_NAME=claude-sonnet-4-6
# HABLE_YA_LLM_MAX_TOKENS=1024

# STT — OpenAI transcription API. Key read from the standard OPENAI_API_KEY.
OPENAI_API_KEY=
# HABLE_YA_STT_MODEL=gpt-4o-transcribe

# TTS — Cartesia. CARTESIA_VOICE_ID has no default; the runtime fails fast if unset.
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# HABLE_YA_CARTESIA_MODEL=sonic-3

# Session auth (spec #016). Shared secret gating /ws/session. Fail-closed: if
# unset, the endpoint refuses ALL connections. Generate a URL-safe random token:
#   openssl rand -hex 32
#   # or: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NOTE: crosses the wire in cleartext until TLS/wss (#017) — don't expose the raw
# ws:// port publicly without a TLS reverse proxy in front.
HABLE_YA_SESSION_AUTH_TOKEN=
# Local-dev only: bypass auth entirely (mirrors dev endpoints). Never set in prod.
# HABLE_YA_SESSION_AUTH_DISABLED=false

# Turn-taking / audio (optional overrides — defaults are the #013-tuned values
# smart_turn=3.0 / vad=0.5; uncomment only to override).
# HABLE_YA_SMART_TURN_STOP_SECS=3.0
# HABLE_YA_VAD_STOP_SECS=0.5
# HABLE_YA_SESSION_IDLE_TIMEOUT_SECS=300
# HABLE_YA_AUDIO_SAMPLE_RATE=16000
